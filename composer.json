{
  "name": "joepdooper/ivy-roots",
  "description": "A set of classes designed to build and extend functionality in ivy",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Ivy\\": "src/"
    }
  },
  "authors": [
    {
      "name": "Joep Dooper"
    }
  ],
  "minimum-stability": "stable",
  "require": {
    "php": ">=8.5.6",
    "ext-pdo": "*",
    "delight-im/auth": "^9.0",
    "phpmailer/phpmailer": "^7.0",
    "bramus/router": "^1.6",
    "vlucas/phpdotenv": "^5.5",
    "latte/latte": "^3.0",
    "symfony/http-foundation": "^8.1",
    "matthiasmullie/minify": "^1.3",
    "php-curl-class/php-curl-class": "^13.0",
    "bainternet/php-hooks": "^1.0",
    "samdark/sitemap": "^3.0",
    "predis/predis": "^3.0@alpha",
    "ezyang/htmlpurifier": "dev-master",
    "blakvghost/php-validator": "^2.3",
    "nesbot/carbon": "^3.11",
    "illuminate/database": "^13.5",
    "illuminate/events": "^13.5",
    "ext-sodium": "*",
    "symfony/mime": "^8.1"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "laravel/pint": "^1.29"
  }
}
